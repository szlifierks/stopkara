<Window x:Class="stopkara.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <StackPanel>
        <ListView x:Name="lista" Height="300">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Tytuł" DisplayMemberBinding="{Binding Tytul}" />
                    <GridViewColumn Header="Autor" DisplayMemberBinding="{Binding Autor.Name}" />
                    <GridViewColumn Header="Gatunek" DisplayMemberBinding="{Binding Gatunek.Name}" />
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
            <ComboBox x:Name="wybor"
                      Width="200"
                      DisplayMemberPath="Name"
                      SelectionChanged="Wybor_OnSelected">
            </ComboBox>
            <Button Content="Dodaj" Margin="10,0,0,0" Click="Dodaj_OnClick" />
            <Button Content="Usuń zaznaczoną" Margin="10,0,0,0" Click="Usun_OnClick" />
        </StackPanel>
    </StackPanel>
</Window>